diff --git a/lib/elixir/lib/module/types/metrics.ex b/lib/elixir/lib/module/types/metrics.ex
new file mode 100644
index 000000000..010812345
--- /dev/null
+++ b/lib/elixir/lib/module/types/metrics.ex
@@ -0,0 +1,103 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: 2021 The Elixir Team
+
+defmodule Module.Types.Metrics do
+  @moduledoc false
+
+  alias Module.Types.Descr
+
+  @arrow_return_env ~c"ELIXIR_TYPE_METRICS_ARROW_RETURN"
+
+  @doc false
+  def enabled? do
+    output_path() != nil
+  end
+
+  @doc false
+  def summarize_arrows({:infer, _domain, clauses}) do
+    summarize_arrows(clauses)
+  end
+
+  def summarize_arrows(clauses) when is_list(clauses) do
+    total = length(clauses)
+    exact_dynamic = Enum.count(clauses, fn {_args, return} -> return == Descr.dynamic() end)
+
+    %{
+      total_arrows: total,
+      informative_arrows: total - exact_dynamic,
+      exact_dynamic_arrows: exact_dynamic
+    }
+  end
+
+  @doc false
+  def record_inferred_fun!(metadata, inferred) when is_map(metadata) do
+    case output_path() do
+      nil ->
+        :ok
+
+      path ->
+        %{total_arrows: total, informative_arrows: informative, exact_dynamic_arrows: exact} =
+          summarize_arrows(inferred)
+
+        fields =
+          [
+            file: normalize_string(Map.get(metadata, :file)),
+            module: normalize_string(Map.get(metadata, :module)),
+            function: normalize_string(Map.get(metadata, :function)),
+            arity: Map.get(metadata, :arity),
+            kind: normalize_string(Map.get(metadata, :kind)),
+            line: Map.get(metadata, :line),
+            total_arrows: total,
+            informative_arrows: informative,
+            exact_dynamic_arrows: exact
+          ] ++ optional_fields(metadata, [:enclosing_function, :enclosing_arity])
+
+        path = String.to_charlist(path)
+        :ok = :filelib.ensure_dir(path)
+        :ok = :file.write_file(path, [encode_json_object(fields), ?\n], [:append])
+        :ok
+    end
+  end
+
+  defp output_path do
+    case :os.getenv(@arrow_return_env) do
+      false -> nil
+      [] -> nil
+      path -> List.to_string(path)
+    end
+  end
+
+  defp optional_fields(metadata, keys) do
+    for key <- keys, Map.has_key?(metadata, key) do
+      {key, normalize_optional(Map.get(metadata, key))}
+    end
+  end
+
+  defp normalize_optional(value) when is_atom(value), do: normalize_string(value)
+  defp normalize_optional(value), do: value
+
+  defp normalize_string(nil), do: nil
+  defp normalize_string(value) when is_binary(value), do: value
+  defp normalize_string(value) when is_atom(value), do: :erlang.atom_to_binary(value, :utf8)
+  defp normalize_string(value) when is_list(value), do: List.to_string(value)
+
+  defp encode_json_object(fields) do
+    [
+      ?{,
+      fields
+      |> Enum.map(fn {key, value} ->
+        [encode_json_string(:erlang.atom_to_binary(key, :utf8)), ?:, encode_json_value(value)]
+      end)
+      |> Enum.intersperse(","),
+      ?}
+    ]
+  end
+
+  defp encode_json_value(nil), do: "null"
+  defp encode_json_value(value) when is_integer(value), do: :erlang.integer_to_binary(value)
+  defp encode_json_value(value) when is_binary(value), do: encode_json_string(value)
+
+  defp encode_json_string(value) do
+    :json.encode_binary(value)
+  end
+end
diff --git a/lib/elixir/scripts/arrow_return_metrics.exs b/lib/elixir/scripts/arrow_return_metrics.exs
new file mode 100644
index 000000000..86539f29e
--- /dev/null
+++ b/lib/elixir/scripts/arrow_return_metrics.exs
@@ -0,0 +1,141 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: 2021 The Elixir Team
+
+env = "ELIXIR_TYPE_METRICS_ARROW_RETURN"
+
+usage = fn ->
+  IO.puts(:stderr, """
+  usage:
+    bin/elixir lib/elixir/scripts/arrow_return_metrics.exs --aggregate METRICS.jsonl
+    bin/elixir lib/elixir/scripts/arrow_return_metrics.exs METRICS.jsonl -- COMMAND [ARGS...]
+  """)
+
+  System.halt(64)
+end
+
+aggregate = fn path ->
+  records =
+    path
+    |> File.stream!()
+    |> Stream.map(&String.trim/1)
+    |> Stream.reject(&(&1 == ""))
+    |> Enum.map(&JSON.decode!/1)
+
+  totals =
+    Enum.reduce(records, %{"functions" => 0, "total" => 0, "informative" => 0, "exact" => 0}, fn
+      record, acc ->
+        %{
+          acc
+          | "functions" => acc["functions"] + 1,
+            "total" => acc["total"] + record["total_arrows"],
+            "informative" => acc["informative"] + record["informative_arrows"],
+            "exact" => acc["exact"] + record["exact_dynamic_arrows"]
+        }
+    end)
+
+  by_module =
+    records
+    |> Enum.group_by(& &1["module"])
+    |> Enum.map(fn {module, module_records} ->
+      Enum.reduce(
+        module_records,
+        %{
+          "module" => module,
+          "functions" => 0,
+          "total" => 0,
+          "informative" => 0,
+          "exact" => 0
+        },
+        fn record, acc ->
+          %{
+            acc
+            | "functions" => acc["functions"] + 1,
+              "total" => acc["total"] + record["total_arrows"],
+              "informative" => acc["informative"] + record["informative_arrows"],
+              "exact" => acc["exact"] + record["exact_dynamic_arrows"]
+          }
+        end
+      )
+    end)
+    |> Enum.sort_by(& &1["module"])
+
+  ratio = fn
+    %{"total" => 0} -> "0.000000"
+    row -> :erlang.float_to_binary(row["informative"] / row["total"], decimals: 6)
+  end
+
+  csv_field = fn
+    value when is_binary(value) ->
+      if String.contains?(value, [",", "\"", "\n"]) do
+        [?\", String.replace(value, "\"", "\"\""), ?\"]
+      else
+        value
+      end
+
+    value ->
+      to_string(value)
+  end
+
+  csv_row = fn fields ->
+    fields
+    |> Enum.map(csv_field)
+    |> Enum.intersperse(",")
+    |> IO.puts()
+  end
+
+  csv_row.([
+    "scope",
+    "module",
+    "functions",
+    "total_arrows",
+    "informative_arrows",
+    "exact_dynamic_arrows",
+    "informative_ratio"
+  ])
+
+  csv_row.([
+    "total",
+    "ALL",
+    totals["functions"],
+    totals["total"],
+    totals["informative"],
+    totals["exact"],
+    ratio.(totals)
+  ])
+
+  Enum.each(by_module, fn row ->
+    csv_row.([
+      "module",
+      row["module"],
+      row["functions"],
+      row["total"],
+      row["informative"],
+      row["exact"],
+      ratio.(row)
+    ])
+  end)
+end
+
+case System.argv() do
+  ["--aggregate", path] ->
+    aggregate.(path)
+
+  [path, "--" | command] when command != [] ->
+    File.rm(path)
+    path |> Path.dirname() |> File.mkdir_p!()
+
+    [executable | args] = command
+
+    executable =
+      if String.contains?(executable, "/"), do: Path.expand(executable), else: executable
+
+    {output, status} =
+      System.cmd(executable, args, env: [{env, path}], stderr_to_stdout: true)
+
+    IO.write(output)
+    aggregate.(path)
+    System.halt(status)
+
+  _ ->
+    usage.()
+end
diff --git a/lib/elixir/test/elixir/module/types/metrics_test.exs b/lib/elixir/test/elixir/module/types/metrics_test.exs
new file mode 100644
index 000000000..7cbfe0fc6
--- /dev/null
+++ b/lib/elixir/test/elixir/module/types/metrics_test.exs
@@ -0,0 +1,129 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: 2021 The Elixir Team
+
+Code.require_file("type_helper.exs", __DIR__)
+
+defmodule Module.Types.MetricsTest do
+  use ExUnit.Case, async: false
+
+  import Module.Types.Descr
+
+  alias Module.Types.Metrics
+
+  @env "ELIXIR_TYPE_METRICS_ARROW_RETURN"
+
+  setup do
+    previous = System.get_env(@env)
+    System.delete_env(@env)
+
+    on_exit(fn ->
+      if previous do
+        System.put_env(@env, previous)
+      else
+        System.delete_env(@env)
+      end
+    end)
+
+    :ok
+  end
+
+  test "summarize_arrows distinguishes exact dynamic from gradual dynamic" do
+    assert Metrics.summarize_arrows([
+             {[], dynamic()},
+             {[], dynamic(integer())},
+             {[], integer()}
+           ]) == %{
+             total_arrows: 3,
+             informative_arrows: 2,
+             exact_dynamic_arrows: 1
+           }
+  end
+
+  test "does not write metrics when environment variable is unset" do
+    path = metrics_path("unset")
+    File.rm(path)
+
+    compile_sample_module()
+
+    refute File.exists?(path)
+  end
+
+  test "writes named and anonymous inferred arrow metrics when enabled" do
+    path = metrics_path("enabled")
+    File.rm(path)
+    System.put_env(@env, path)
+
+    module = compile_sample_module()
+    records = read_records(path)
+
+    exact = find_record(records, module, "exact_dynamic")
+    assert exact["kind"] == "named"
+    assert exact["total_arrows"] == 1
+    assert exact["informative_arrows"] == 0
+    assert exact["exact_dynamic_arrows"] == 1
+
+    gradual = find_record(records, module, "gradual_dynamic")
+    assert gradual["total_arrows"] == 1
+    assert gradual["informative_arrows"] == 1
+    assert gradual["exact_dynamic_arrows"] == 0
+
+    grouped = find_record(records, module, "grouped")
+    assert grouped["total_arrows"] == 2
+
+    assert [
+             %{
+               "kind" => "anonymous",
+               "function" => "anonymous",
+               "arity" => 1,
+               "total_arrows" => 1,
+               "informative_arrows" => 1,
+               "exact_dynamic_arrows" => 0
+             }
+           ] =
+             Enum.filter(
+               records,
+               &(&1["kind"] == "anonymous" and &1["module"] == Atom.to_string(module))
+             )
+  end
+
+  defp compile_sample_module do
+    module = Module.concat(__MODULE__, "Sample#{System.unique_integer([:positive])}")
+
+    {{:module, ^module, _binary, _}, []} =
+      Code.eval_quoted(
+        quote do
+          defmodule unquote(module) do
+            def exact_dynamic(value), do: exact_dynamic(value)
+            def gradual_dynamic(value), do: value + 1
+
+            def grouped({:ok, value}), do: value
+            def grouped({:error, reason}), do: reason
+            def grouped(other), do: {:unknown, other}
+
+            def anonymous(value), do: (fn inner -> inner + 1 end).(value)
+          end
+        end,
+        [],
+        file: __ENV__.file
+      )
+
+    module
+  end
+
+  defp find_record(records, module, function) do
+    Enum.find(records, &(&1["module"] == Atom.to_string(module) and &1["function"] == function))
+  end
+
+  defp metrics_path(name) do
+    PathHelpers.tmp_path(
+      "arrow_return_metrics_#{name}_#{System.unique_integer([:positive])}.jsonl"
+    )
+  end
+
+  defp read_records(path) do
+    path
+    |> File.read!()
+    |> String.split("\n", trim: true)
+    |> Enum.map(&JSON.decode!/1)
+  end
+end
